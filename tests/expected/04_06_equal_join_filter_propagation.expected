| name | val |
| a2 | b2 |
Project(columns=[a.name, b.val], rows=1)
	Join(tables=[a75, b75], condition=[a.id=b.aid], rows=1)
		Project(columns=[a.id, a.name], rows=1)
			Filter(condition=[a.id=2], rows=1)
				Scan(table=a75, type=SeqScan, rows=3)
		Project(columns=[b.aid, b.val], rows=1)
			Filter(condition=[b.aid=2], rows=1)
				Scan(table=b75, type=SeqScan, rows=3)
